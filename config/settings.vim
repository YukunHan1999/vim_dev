syntax on
set number              " 显示行号
set timeout             " 启用超时时间
set timeout=500         " 设置超时时间
 20 set timeoutlen=500
set tabstop=4           " Tab 宽度
set shiftwidth=4
set expandtab           " Tab 转空格
set autoindent          " 自动缩进
set hlsearch            " 高亮搜索
set ignorecase          " 搜索忽略大小写
set smartcase           " 智能大小写
set undofile            " 开启持久化撤销
set undodir=~/.vim/undodir